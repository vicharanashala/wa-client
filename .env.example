# Database Configuration
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# WhatsApp Meta Business API Configuration
META_ACCESS_TOKEN=your_meta_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# LLM Configuration (Ajarsaka or OpenAI-compatible API)
LLM_BASE_URL=http://localhost:4123/v1
LLM_API_KEY=dummy-key-or-actual-api-key
LLM_MODEL=default

# AI Behavior Configuration
SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Keep responses concise and conversational. Respond in the same language the user is using.
MAX_TOKENS=500
TEMPERATURE=0.7
PRESENCE_PENALTY=0.6

# Bot Messages Configuration
FALLBACK_RESPONSE=Sorry, I encountered an issue. Please try again.
CLEAR_SUCCESS_MESSAGE=✅ Conversation history cleared! We can start fresh.
HELP_MESSAGE=🤖 *WhatsApp AI Assistant*\n\nAvailable commands:\n• Just send any message to chat with me\n• **/clear** - Clear conversation history\n• **/help** - Show this help message\n\nI can help with questions, conversations, and more!

# Application Configuration
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=debug