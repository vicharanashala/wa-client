# ==============================================================================
# SECRETS & CREDENTIALS - Environment Variables
# ==============================================================================
# This file contains ONLY sensitive data that should NEVER be committed.
# All non-secret configuration is in config.yaml
# ==============================================================================

# ==============================================================================
# DATABASE CREDENTIALS (REQUIRED)
# ==============================================================================
# MongoDB connection string - REQUIRED
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# ==============================================================================
# REDIS CREDENTIALS (OPTIONAL - Not currently used in code)
# ==============================================================================
# Note: Redis configuration is referenced but not actively implemented
# Uncomment and configure if you plan to implement Redis caching
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==============================================================================
# WHATSAPP META BUSINESS API CREDENTIALS (REQUIRED)
# ==============================================================================
# WhatsApp Business API access token - REQUIRED
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# WhatsApp Business phone number ID - REQUIRED
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook verification token (for Meta webhook subscription) - REQUIRED
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Meta app secret for webhook signature verification - REQUIRED
WHATSAPP_META_APP_SECRET=your_meta_app_secret_here

# Note: META_ACCESS_TOKEN is an alias for WHATSAPP_ACCESS_TOKEN (only used in logging)
# You can optionally set it to the same value as WHATSAPP_ACCESS_TOKEN

# ==============================================================================
# LLM API CREDENTIALS (REQUIRED)
# ==============================================================================
# LLM API Key - REQUIRED (this is sensitive!)
LLM_API_KEY=your-llm-api-key-here

# ==============================================================================
# EXTERNAL AI SERVICE API KEYS (REQUIRED for features)
# ==============================================================================
# Sarvam AI API Key (for Speech-to-Text and Text-to-Speech) - REQUIRED for voice features
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini API Key (for voice calls with Gemini Live) - REQUIRED for voice call features
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# OPTIONAL: Runtime Configuration Overrides
# ==============================================================================
# These environment variables can override config.yaml values at runtime.
# Normally, you should configure these in config.yaml instead.
# Only use these for temporary testing or deployment-specific overrides.
# ==============================================================================

# Application Environment (development, production, test)
# Default from config.yaml: development
# NODE_ENV=development

# Application Port
# Default from config.yaml: 3000
# PORT=3000

# Logging Level (error, warn, info, debug)
# Default from config.yaml: debug
# LOG_LEVEL=debug

# LLM Base URL (can override config.yaml)
# Default: http://34.180.40.201:8081/v1
# LLM_BASE_URL=http://localhost:4123/v1

# LLM Model Name (can override config.yaml)
# Default from config.yaml: Qwen/Qwen3-30B-A3B
# LLM_MODEL=Qwen/Qwen3-30B-A3B

# Max Tokens for LLM responses (can override config.yaml)
# Default from config.yaml: 1024
# MAX_TOKENS=1024

# LLM Temperature (creativity/randomness) (can override config.yaml)
# Default from config.yaml: 0.7
# TEMPERATURE=0.7

# WhatsApp API Version (can override config.yaml)
# Default from config.yaml: v18.0
# WHATSAPP_API_VERSION=v18.0

# Reviewer System API Base URL (can override config.yaml)
# Default from config.yaml: http://100.100.108.43:9007/api
# REVIEWER_API_BASE_URL=http://100.100.108.43:9007/api

# Reviewer Polling Interval in milliseconds (can override config.yaml)
# Default from config.yaml: 7200000 (2 hours)
# REVIEWER_POLL_INTERVAL_MS=7200000

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Variables marked as REQUIRED must be set for the application to work
# 2. Variables in the "Optional: Runtime Configuration Overrides" section
#    are typically managed in config.yaml and only need to be set here for
#    temporary overrides or environment-specific values
# 3. Never commit this file with actual secrets to version control
# 4. All non-secret configuration should be in config.yaml instead
# ==============================================================================
